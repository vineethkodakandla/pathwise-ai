# Frontend environment variables (Vite).
#
# Local dev: leave VITE_API_URL unset. The Vite dev server (npm run dev) proxies
# /api and /ws to http://localhost:8000 automatically (see vite.config.ts).
#
# Cloud (Vercel): set VITE_API_URL to your deployed backend origin, e.g.
#   VITE_API_URL=https://pathwise-ai-api.onrender.com
# The frontend then calls REST at $VITE_API_URL/api/v1/... and opens the
# WebSocket at the matching wss:// origin.
VITE_API_URL=
